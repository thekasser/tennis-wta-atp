# Tennis Dashboard — environment variables
# Copy this file to `.env` (which is gitignored) and fill in your real values.

# ── Matchstat (Tennis API on RapidAPI) ───────────────────────────────────────
# Subscribe at: https://rapidapi.com/jjrm365-kIFr3Nx_odV/api/tennis-api-atp-wta-itf
# After subscribing, find your key under "Endpoints" → "Header Parameters".
MATCHSTAT_API_KEY=your_rapidapi_key_here
MATCHSTAT_API_HOST=tennis-api-atp-wta-itf.p.rapidapi.com

# RapidAPI app metadata (optional — for tracking / multi-key support)
# RAPIDAPI_APP_ID=
# RAPIDAPI_USER=
